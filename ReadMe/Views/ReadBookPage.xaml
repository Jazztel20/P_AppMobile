<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.Views.ReadBookPage"
             Title=""
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" BackgroundColor="#87CEEB" Padding="12,8,12,10">
            <Grid ColumnDefinitions="50,*,Auto">
                <Image Grid.Column="0"
                       Source="readingghostpng.png"
                       HeightRequest="42" WidthRequest="42"
                       VerticalOptions="Center"/>
                <Border Grid.Column="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#bbb" StrokeThickness="1"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        Padding="20,5">
                    <Label Text="README" FontSize="14" FontAttributes="Bold"
                           TextColor="#333" HorizontalOptions="Center"/>
                </Border>
                <Border Grid.Column="2"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 18"
                        Stroke="#bbb" StrokeThickness="1"
                        Padding="10,5" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="👤" FontSize="13" VerticalOptions="Center"/>
                        <Label Text="User 1" FontSize="13" TextColor="#333"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ BOOK TITLE + AUTHOR ══ -->
        <VerticalStackLayout Grid.Row="1" Padding="16,14,16,8" Spacing="2">
            <Label x:Name="BookTitleLabel"
                   FontSize="18" FontAttributes="Bold" TextColor="#222"/>
            <Label x:Name="BookAuthorLabel"
                   FontSize="13" TextColor="#888" FontAttributes="Italic"/>
        </VerticalStackLayout>

        <!-- ══ EPUB CONTENT ══ -->
        <WebView Grid.Row="2"
                 x:Name="BookWebView"
                 Margin="12,0"/>

        <!-- ══ BOTTOM NAV ══ -->
        <Grid Grid.Row="3"
              Padding="8,6"
              ColumnDefinitions="*,Auto,Auto"
              BackgroundColor="White">
            <BoxView Grid.ColumnSpan="3"
                     HeightRequest="1" Color="#eee"
                     VerticalOptions="Start"/>
            <Button Grid.Column="0"
                    Text="← Retour à la page d'accueil"
                    BackgroundColor="Transparent"
                    TextColor="#555" FontSize="12"
                    HorizontalOptions="Start"
                    Clicked="OnGoHomeClicked"/>
            <Button Grid.Column="1"
                    x:Name="previousBtn"
                    Text="← Page précédente"
                    BackgroundColor="Transparent"
                    TextColor="#555" FontSize="12"
                    Clicked="OnPreviousClicked"/>
            <Button Grid.Column="2"
                    x:Name="nextBtn"
                    Text="Page suivante →"
                    BackgroundColor="Transparent"
                    TextColor="#555" FontSize="12"
                    Clicked="OnNextClicked"/>
        </Grid>

        <!-- ══ FOOTER ══ -->
        <Grid Grid.Row="4" BackgroundColor="#87CEEB"
              Padding="16,12" ColumnDefinitions="*,*">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Suivez-nous" FontAttributes="Bold" TextColor="#222" FontSize="13"/>
                <HorizontalStackLayout Spacing="10" Margin="0,4">
                    <Label Text="📷" FontSize="20"/>
                    <Label Text="f"  FontSize="20" FontAttributes="Bold"/>
                    <Label Text="in" FontSize="18" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Text="© Vibe" TextColor="#444" FontSize="11" Margin="0,6"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="End">
                <Label Text="Contactez-nous" FontAttributes="Bold" TextColor="#222" FontSize="13"/>
                <Label Text="vincent.panzetta@eduvaud.ch" TextColor="#444" FontSize="11"/>
                <Label Text="+41.79.xxx.xx.xx" TextColor="#444" FontSize="11"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
