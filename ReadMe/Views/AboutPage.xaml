<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.Views.AboutPage"
             Title="À propos">
    <ScrollView Padding="30">
        <StackLayout Spacing="25" VerticalOptions="Center">
            <Label Text="ReadMe"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Version 0.0.1"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <BoxView HeightRequest="2"
                     Color="LightGray"
                     HorizontalOptions="Fill" />

            <Label Text="Liseuse de livres en ligne"
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <Border Stroke="{DynamicResource Primary}"
                    StrokeShape="RoundRectangle 10"
                    Padding="20"
                    Margin="0,20,0,0">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Fonctionnalités"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Label Text="• Consulter les livres d'une base de données"
                           FontSize="16"/>
                    <Label Text="• Voir les informations d'un livre"
                           FontSize="16"/>
                    <Label Text="• Trier les livres par date d'ajout"
                           FontSize="16"/>
                    <Label Text="• Filtrer les livres par tags et par catégories"
                           FontSize="16"/>
                    <Label Text="• Créer des tags et les ajouter aux livres"
                           FontSize="16"/>
                    <Label Text="• Lecture de e-book"
                           FontSize="16"/>
                    <Label Text="• Navigation entre les pages en pressant sur des boutons"
                           FontSize="16"/>
                    <Label Text="• Reprise automatique de la dernière page affichée"
                           FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Comment utiliser l'application"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,30,0,10"/>

            <Border Stroke="LightGray"
                    StrokeShape="RoundRectangle 10"
                    Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="1. Rendez-vous sur la page des e-books"
                           FontSize="15"/>
                    <Label Text="2. Choisissez le livre à lire"
                           FontSize="15"/>
                    <Label Text="3. Bonne lecture !"
                           FontSize="15"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Développé avec .NET MAUI"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray"
                   Margin="0,30,0,0"/>

        </StackLayout>
    </ScrollView>
</ContentPage>