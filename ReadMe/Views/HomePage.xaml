<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.Views.HomePage"
             Title="">
    <ScrollView>
        <VerticalStackLayout 
            Padding="30, 0"
            Spacing="25"
            VerticalOptions="Center">
            <Image 
                Source="readingghostpng.png"
                HeightRequest="200"
                Aspect="AspectFit"
                SemanticProperties.Description="Reading Ghost (logo)" />
            <Label
                Text="ReadMe"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <BoxView HeightRequest="2"
                  Color="LightGray"
                  HorizontalOptions="Fill" />

            <Label Text="Bienvenue sur ReadMe, votre nouvelle liseuse favorite !" />

            <Button
                x:Name="StartReadingBtn"
                Text="Commencez à lire"
                SemanticProperties.Hint="Go to e-books page"
                Clicked="OnNavigateToEBookPageClicked"
                BackgroundColor="Black"
                TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>